<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE scenario SYSTEM "sipp.dtd">

<!--
  Mock SIP registrar with Digest challenge AND password verification.

  Flow:
    REGISTER  ->  401 Unauthorized + WWW-Authenticate
    REGISTER  ->  200 OK if username + digest response match,
                  call fails (check_it="true") otherwise.

  Required dongle credentials:
    SIP-User:    phoneblock-dongle
    SIP-Pass:    dongle-password

  Run via run-auth-registrar.sh — the wrapper computes the
  expected digest response for the configured host IP and passes
  it in via `-key expected_response`. The challenge intentionally
  drops qop, so the response is deterministic:

      HA1      = MD5("phoneblock-dongle:phoneblock.test:dongle-password")
      HA2      = MD5("REGISTER:sip:<HOST_IP>")
      response = MD5(HA1:0123456789abcdef:HA2)

  The dongle picks the no-qop branch in digest_response() when our
  challenge omits qop (sip_register.c:267-272), so this matches the
  on-device math exactly. With qop="auth" the response would mix in
  cnonce + nc and we couldn't pre-compute it; that's why qop is left
  out here.
-->
<scenario name="PhoneBlock Dongle Mock Registrar (Digest)">

  <recv request="REGISTER"/>

  <send>
    <![CDATA[

      SIP/2.0 401 Unauthorized
      [last_Via:]
      [last_From:]
      [last_To:];tag=[pid]SIPpTag01[call_number]
      [last_Call-ID:]
      [last_CSeq:]
      WWW-Authenticate: Digest realm="phoneblock.test", nonce="0123456789abcdef", algorithm=MD5
      Server: SIPp Mock Registrar (PhoneBlock dongle test-rig)
      Content-Length: 0

    ]]>
  </send>

  <!--
    Verify the dongle's Authorization header. Both regexes are
    `check_it="true"` so SIPp fails the call if either field is
    wrong — that is what makes this a real auth test rather than a
    decorative one. The expected digest response is supplied at
    invocation time via `-key expected_response <hash>`.
  -->
  <recv request="REGISTER">
    <action>
      <ereg regexp='username="phoneblock-dongle"'
            search_in="hdr"
            header="Authorization:"
            check_it="true"
            assign_to="user_match"/>
      <ereg regexp='response="[$expected_response]"'
            search_in="hdr"
            header="Authorization:"
            check_it="true"
            assign_to="hash_match"/>
      <log message="REGISTER authenticated: user_match=[$user_match] hash_match=[$hash_match]"/>
    </action>
  </recv>

  <send>
    <![CDATA[

      SIP/2.0 200 OK
      [last_Via:]
      [last_From:]
      [last_To:];tag=[pid]SIPpTag02[call_number]
      [last_Call-ID:]
      [last_CSeq:]
      [last_Contact:];expires=300
      Server: SIPp Mock Registrar (PhoneBlock dongle test-rig)
      Content-Length: 0

    ]]>
  </send>

  <ResponseTimeRepartition value="10, 50, 100, 250, 500, 1000"/>
</scenario>
