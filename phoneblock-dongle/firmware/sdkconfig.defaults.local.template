# Template for sdkconfig.defaults.local. Copy, fill in, rebuild:
#
#   cp sdkconfig.defaults.local.template sdkconfig.defaults.local
#   $EDITOR sdkconfig.defaults.local
#   rm sdkconfig && idf.py build
#
# Only values that need to differ from sdkconfig.defaults belong here.
# sdkconfig.defaults.local is gitignored — real credentials stay local.
# See sdkconfig.defaults for the documented list of available knobs.

# Backend. Default in sdkconfig.defaults is production
# (https://phoneblock.net/phoneblock); the test instance lives at
# /pb-test. Tokens are bound to one instance.
CONFIG_PHONEBLOCK_BASE_URL="https://phoneblock.net/pb-test"

# --- Real ESP32 hardware: WiFi instead of QEMU's OpenCores Ethernet. ---
# Leave the whole block commented on QEMU builds.
CONFIG_EXAMPLE_CONNECT_ETHERNET=n
CONFIG_EXAMPLE_USE_OPENETH=n
CONFIG_EXAMPLE_CONNECT_WIFI=y
# Fill in your WiFi credentials before building. Leaving the
# placeholder values active produces a build that silently fails to
# associate, so the lines stay commented out in the template.
#CONFIG_EXAMPLE_WIFI_SSID=""
#CONFIG_EXAMPLE_WIFI_PASSWORD=""

# Dev-only: answer **/* internal Fritz!Box codes as spam so the
# 200 OK + tone + BYE path runs without blacklisting a real number.
CONFIG_SIP_TEST_FORCE_SPAM_STAR_NUMBERS=y

# EGBO PICO-D4 dongle: status LED on GPIO 10 (overrides the default 2
# from sdkconfig.defaults, which targets WROOM-32 dev boards).
#CONFIG_STATUS_LED_GPIO=10

# --- QEMU only: host-visible address + forwarded port so the ----------
# Fritz!Box can deliver INVITEs through QEMU's user-mode NAT.
# Leave commented on real hardware.
#CONFIG_SIP_CONTACT_HOST_OVERRIDE="192.168.178.22"
#CONFIG_SIP_CONTACT_PORT_OVERRIDE=5061
