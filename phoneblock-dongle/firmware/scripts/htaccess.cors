# Web-Installer auf https://phoneblock.net lädt von hier:
#   - install-button.js als ES-Modul       (CORS-Pflicht)
#   - manifest.json per fetch()            (CORS-Pflicht)
#   - bootloader/partition-table/app.bin   (CORS-Pflicht)
# Static, keine Credentials → ACAO "*" ist sicher.
<IfModule mod_headers.c>
    Header set Access-Control-Allow-Origin "*"
</IfModule>
